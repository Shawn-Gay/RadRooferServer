@page "/dashboard"
@model DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<h2 class="mb-4">Recent Activity</h2>

<div class="row g-4">
    <div class="col-12">
        <h4>Customers <span class="badge bg-secondary">@Model.Customers.Count</span></h4>
        <table class="table table-striped table-sm">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Company</th>
                    <th>Type</th>
                    <th>Source</th>
                    <th>Added</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model.Customers)
                {
                    <tr>
                        <td>@customer.FirstName @customer.LastName</td>
                        <td>@(customer.CompanyName ?? "—")</td>
                        <td>@customer.CustomerType</td>
                        <td>@customer.LeadSource</td>
                        <td>@customer.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</td>
                    </tr>
                }
                @if (!Model.Customers.Any())
                {
                    <tr><td colspan="5" class="text-muted">No customers yet.</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="col-12">
        <h4>Recent Calls <span class="badge bg-secondary">@Model.Calls.Count</span></h4>
        <table class="table table-striped table-sm">
            <thead>
                <tr>
                    <th>Direction</th>
                    <th>Status</th>
                    <th>Summary</th>
                    <th>Started</th>
                    <th>Ended</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var call in Model.Calls)
                {
                    <tr>
                        <td>@call.Direction</td>
                        <td>@call.Status</td>
                        <td>@(call.Summary ?? "—")</td>
                        <td>@call.StartedAt.ToLocalTime().ToString("MMM d, h:mm tt")</td>
                        <td>@(call.EndedAt?.ToLocalTime().ToString("MMM d, h:mm tt") ?? "—")</td>
                    </tr>
                }
                @if (!Model.Calls.Any())
                {
                    <tr><td colspan="5" class="text-muted">No calls yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
