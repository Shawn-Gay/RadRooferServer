@page "/dashboard"
@model DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-5">
    <h4 class="mb-3">AI Assistant</h4>
    @foreach (var location in Model.Locations)
    {
        <div class="card mb-2" style="max-width: 480px;">
            <div class="card-body d-flex align-items-center justify-content-between py-3">
                <div>
                    <div class="fw-semibold">@location.Name</div>
                    <small class="@(location.VapiEnabled ? "text-success" : "text-muted")">
                        @(location.VapiEnabled ? "Taking calls" : "Calls not being answered by assistant")
                    </small>
                </div>
                <form method="post" asp-page-handler="ToggleAssistant">
                    <input type="hidden" name="locationId" value="@location.Id" />
                    <button type="submit" class="btn @(location.VapiEnabled ? "btn-success" : "btn-outline-secondary") d-flex align-items-center gap-2">
                        <span class="rounded-circle d-inline-block" style="width:10px;height:10px;background:@(location.VapiEnabled ? "#fff" : "#aaa");"></span>
                        @(location.VapiEnabled ? "On" : "Off")
                    </button>
                </form>
            </div>
        </div>
    }
</div>

<h2 class="mb-4">Recent Activity</h2>

<div class="row g-4">
    <div class="col-12">
        <h4>Customers <span class="badge bg-secondary">@Model.Customers.Count</span></h4>
        <table class="table table-striped table-sm">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Company</th>
                    <th>Type</th>
                    <th>Source</th>
                    <th>Added</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var customer in Model.Customers)
                {
                    <tr>
                        <td>@customer.FirstName @customer.LastName</td>
                        <td>@(customer.CompanyName ?? "—")</td>
                        <td>@customer.CustomerType</td>
                        <td>@customer.LeadSource</td>
                        <td>@customer.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</td>
                    </tr>
                }
                @if (!Model.Customers.Any())
                {
                    <tr><td colspan="5" class="text-muted">No customers yet.</td></tr>
                }
            </tbody>
        </table>
    </div>

    <div class="col-12">
        <h4>Recent Calls <span class="badge bg-secondary">@Model.Calls.Count</span></h4>
        <table class="table table-striped table-sm">
            <thead>
                <tr>
                    <th>Direction</th>
                    <th>Status</th>
                    <th>Summary</th>
                    <th>Started</th>
                    <th>Ended</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var call in Model.Calls)
                {
                    <tr>
                        <td>@call.Direction</td>
                        <td>@call.Status</td>
                        <td>@(call.Summary ?? "—")</td>
                        <td>@call.StartedAt.ToLocalTime().ToString("MMM d, h:mm tt")</td>
                        <td>@(call.EndedAt?.ToLocalTime().ToString("MMM d, h:mm tt") ?? "—")</td>
                    </tr>
                }
                @if (!Model.Calls.Any())
                {
                    <tr><td colspan="5" class="text-muted">No calls yet.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
